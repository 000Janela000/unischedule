{
  "manifest_version": 3,
  "name": "UniHub EMIS Connector",
  "version": "1.1.0",
  "description": "აგრარული უნივერსიტეტის სტუდენტებისთვის — ნიშნები, GPA და ფინანსები UniHub-ზე",
  "permissions": ["storage"],
  "host_permissions": [
    "https://emis.campus.edu.ge/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://emis.campus.edu.ge/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://unihub-edu.vercel.app/*", "http://localhost:3000/*"],
      "js": ["sync.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://unihub-edu.vercel.app/*",
      "http://localhost:3000/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
